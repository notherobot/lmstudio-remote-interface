{
  "name": "lmstudio-chat",
  "version": "1.0.0",
  "description": "Chat interface for LM Studio",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.lmstudio.chat",
    "productName": "LM Studio Chat",
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "marked.min.js",
      "manifest.json",
      "icon-192.png",
      "icon-512.png",
      "electron/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon-512.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
